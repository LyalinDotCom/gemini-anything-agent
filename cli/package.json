{
  "name": "@lyalindotcom/gai",
  "version": "0.3.0",
  "private": false,
  "description": "Media and agent-management CLI for Gemini Anything managed agents.",
  "type": "module",
  "bin": {
    "gai": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/fix-bin-mode.mjs",
    "prepack": "npm run build",
    "dev": "tsx src/cli.ts",
    "gai": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "mime-types": "^3.0.1",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  },
  "engines": {
    "node": ">=22"
  }
}
